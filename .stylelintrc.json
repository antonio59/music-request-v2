{
  "extends": [
    "stylelint-config-standard"
  ],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "theme",
          "utility",
          "custom-variant",
          "variant",
          "source",
          "plugin"
        ]
      }
    ],
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": [
          "theme"
        ]
      }
    ],
    "import-notation": "string",
    "no-invalid-position-at-import-rule": null,
    "selector-class-pattern": null,
    "custom-property-pattern": null
  }
}
