# Environment Variables
PORT=3001
JWT_SECRET=music-request-secret-change-in-production

# YouTube API Key (optional - falls back to mock data)
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Internxt Cloud Storage (optional - falls back to mock URLs)
# Sign up at internxt.com → Settings → App Keys
INTERNXT_EMAIL=
INTERNXT_PASSWORD=
INTERNXT_APP_KEY=

# File paths
DOWNLOAD_DIR=./downloads
DB_PATH=./data/music-request.db
