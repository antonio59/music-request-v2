# Local development
VITE_SENTRY_DSN=your_sentry_dsn_here
SENTRY_DSN=your_sentry_dsn_here

# Production (VPS): set both env vars on your server.
# VITE_SENTRY_DSN must be present at build time so Vite can inline it.
# SENTRY_DSN is read at runtime by the Express backend.
# Do NOT commit the real DSNs to git.
